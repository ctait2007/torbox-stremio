{
  "id": "community.torbox-tmdb-catalogue",
  "version": "1.0.0",
  "name": "TorBox Library",
  "description": "Generates a personal catalogue from your TorBox library, enriched with metadata from TMDB.",
  "logo": "https://torbox.app/favicon.ico",
  "background": "https://image.tmdb.org/t/p/original/jf7AWfBrGROEd8dOQtLGmOYIRuQ.jpg",
  "contactEmail": "your@email.com",
  "resources": ["catalog", "stream"],
  "types": ["movie", "series", "anime"],
  "idPrefixes": ["tt"],
  "catalogs": [
    {
      "id": "torbox-movies",
      "type": "movie",
      "name": "TorBox Library",
      "extra": [
        { "name": "skip", "isRequired": false }
      ],
      "extraSupported": ["skip"]
    },
    {
      "id": "torbox-series",
      "type": "series",
      "name": "TorBox Library",
      "extra": [
        { "name": "skip", "isRequired": false }
      ],
      "extraSupported": ["skip"]
    },
        {
      "id": "torbox-anime",
      "type": "anime",
      "name": "TorBox Library",
      "extra": [
        { "name": "skip", "isRequired": false }
      ],
      "extraSupported": ["skip"]
    }
  ],
  "behaviorHints": {
    "adult": false,
    "p2p": false
  }
}
